# ==========================================
# ZDEM Salt Kinematics 环境配置模板
# 使用方式：复制本文件为 .env，修改为本地实际值
# ==========================================

# --- 1. 核心目录 ---
# 填写包含各实验组子文件夹的根路径。推荐使用绝对路径以避免解析歧义。
FINAL_OUTPUT_DIR="E:\0.Information\4.Temp\StructLab\Projects\18_盐构造模拟\实验\71.不同沉积速率"

# --- 2. 实验组配置 (JSON 格式) ---
# 受 python-dotenv 解析机制限制，EXPERIMENT_GROUPS 的 JSON 数组必须严格写在同一行，严禁换行。
# 每组包含：
#   - subdir: 子目录名 (需包含 data 文件夹)
#   - label: LaTeX 格式的学术标签 (用于图例)
#   - color: 十六进制颜色代码
#   - marker: Matplotlib 标准标记符号
EXPERIMENT_GROUPS=[{"subdir": "150", "label": "$v_s = 150 \\ m \\cdot s^{-1}$", "color": "#0a2f51", "marker": "o"}, {"subdir": "300", "label": "$v_s = 300 \\ m \\cdot s^{-1}$", "color": "#2e6f8e", "marker": "s"}, {"subdir": "600", "label": "$v_s = 600 \\ m \\cdot s^{-1}$", "color": "#4cb876", "marker": "^"}]

# --- 3. 持久化文件名 ---
# 提取出的演化指标 CSV 文件名
CSV_FILENAME="kinematics_data.csv"
# 剖面形态缓存 Pickle 文件名
PKL_FILENAME="profiles_cache.pkl"

# --- 4. 物理模型尺寸与绘图视口 (单位: m) ---
MODEL_WIDTH=80000.0          # 离散元实验区域的水平总宽度
MODEL_HEIGHT=30000.0         # 离散元实验区域的垂直总高度
MANUAL_PLOT_Y_MIN=5000.0     # 01b 质控脚本绘图窗口 Y 轴下限
MANUAL_PLOT_Y_MAX=25000.0    # 01b 质控脚本绘图窗口 Y 轴上限
MAX_SHORTENING_KM=24.0       # 最终汇总图 X 轴 (缩短量) 最大刻度 (单位: km)
MAX_ASPECT_RATIO=1.20        # 最终汇总图 Y 轴 (高宽比) 最大刻度

# --- 5. 颗粒物理参数与特征提取算法阈值 ---
PUSHING_WALL_SIDE="right"      # 挤压墙体方位 (left/right)
MIN_RELIEF_THRESHOLD=100.0      # 判定为有效变形的最小隆起高度 (m)
SALT_GROUP_NAME="salt"         # 离散元数据中盐岩层的 Group 名称
PARTICLE_RADIUS=70.0           # 离散元颗粒平均物理半径 (m)
NUM_BINS=300                   # 提取地表包络线时的网格采样精度
SMOOTHING_WINDOW=3             # 时间序列 (演化折线) 滑动平均平滑跨度
EXTRACT_SMOOTH_WINDOW=31       # 空间序列 (剖面曲线) 过滤噪声的 SG 平滑跨度
PRE_EXTRUSION_FRAMES=25        # 出露地表前等距采样帧数 (预留)
POST_EXTRUSION_FRAMES=10       # 出露地表后强制保留帧数 (预留)
FLANK_SLOPE_THRESHOLD=0.15     # 锚定基点的局部坡度 (一阶导数) 阈值

# --- 6. 视觉风格配置 (QA/QC 界面) ---
COLOR_PRIMARY="#3498db"
COLOR_SECONDARY="#e67e22"
COLOR_GRID="#bdc3c7"
COLOR_TEXT_MAIN="#2c3e50"
COLOR_TEXT_SUB="#7f8c8d"
