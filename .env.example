# ==========================================
# ZDEM Salt Kinematics 环境配置模板
# 使用方式：复制本文件为 .env，修改为本地实际值
# ==========================================

# --- 1. 核心目录 ---
# 输出数据的最终保存目录（绝对路径，建议用正斜杠或双反斜杠）
FINAL_OUTPUT_DIR="E:/0.Information/4.Temp/StructLab/Projects/18_盐构造模拟/实验/70.不同挤压速率"

# --- 2. 实验组 (JSON 格式) ---
# 每组包含：子目录名、LaTeX 标签、颜色代码、标记符号
# 注意：JSON 数组，所有字段必须用双引号
EXPERIMENT_GROUPS=[
    {"subdir": "1.0", "label": "$v = 1.0 \\ m \\cdot s^{-1}$", "color": "b", "marker": "o"},
    {"subdir": "2.0", "label": "$v = 2.0 \\ m \\cdot s^{-1}$", "color": "r", "marker": "s"},
    {"subdir": "3.0", "label": "$v = 3.0 \\ m \\cdot s^{-1}$", "color": "g", "marker": "^"}
]

# --- 3. 输出文件名 ---
# 主要输出的 CSV 和 PKL 文件名
CSV_FILENAME="kinematics_data.csv"
PKL_FILENAME="profiles_cache.pkl"

# --- 4. 模型大小与图表边界 ---
MODEL_WIDTH=80000.0          # 离散元实验区域的水平总宽度 (单位: m)
MODEL_HEIGHT=30000.0         # 离散元实验区域的垂直总高度 (单位: m)
MANUAL_PLOT_Y_MIN=5000.0     # 01b 脚本进行人工核对时，绘图窗口 Y 轴的下限 (单位: m)
MANUAL_PLOT_Y_MAX=25000.0    # 01b 脚本进行人工核对时，绘图窗口 Y 轴的上限 (单位: m)
MAX_SHORTENING_KM=24.0       # 最终汇总折线图 X 轴 (挤压缩短量) 的最大刻度 (单位: km)
MAX_ASPECT_RATIO=1.20        # 最终汇总折线图 Y 轴 (高宽比) 的最大刻度

# --- 5. 实验参数与特征提取阈值 ---
PUSHING_WALL_SIDE="right"      # 挤压墙体所在的方位 (固定从右侧往左挤，填 "right")
MIN_RELIEF_THRESHOLD=50.0      # 最小有效起伏度阈值。若隆起高度低于此值，视为未发生有效变形 (单位: m)
SALT_GROUP_NAME="salt"         # 离散元模型数据中，代表“盐岩层”的颗粒 Group 名称
PARTICLE_RADIUS=70.0           # 离散元颗粒的平均半径 (用于精准计算溢出地表部分的面积，单位: m)
NUM_BINS=300                   # 提取地表包络线时的网格分箱数量 (决定空间分辨率)
SMOOTHING_WINDOW=3             # 时间序列 (最终演化折线图) 消除数值震荡的滑动平均平滑跨度
EXTRACT_SMOOTH_WINDOW=31       # 空间序列 (单张盐层剖面曲线) 过滤颗粒凹凸噪声的 Savitzky-Golay 平滑跨度
PRE_EXTRUSION_FRAMES=25        # 盐体刺穿出露地表前，在时间序列上等距强制采样的帧数
POST_EXTRUSION_FRAMES=10        # 盐体刺穿出露地表后，强制保留的演化末段帧数
FLANK_SLOPE_THRESHOLD=0.15     # 判定形变前锋边界的局部一阶导数 (斜率) 阈值，用于精准锚定非挤压端基点