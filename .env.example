# ZDEM Salt Kinematics Configuration

# --- 存储路径 ---
# 所有实验组的父目录
FINAL_OUTPUT_DIR=E:/0.Information/1.Code Projects/9.ZDEM_Salt_Kinematics/output

# 各组输出文件名
CSV_FILENAME=kinematics_metrics.csv
PKL_FILENAME=profiles_cache.pkl

# --- 实验组 JSON 定义 ---
# subdir: 相对于 FINAL_OUTPUT_DIR 的子文件夹（存放该组 dat 的 data 目录应在其中）
# label: 图例显示的名称
# color: 绘图颜色
# marker: 绘图点型
EXPERIMENT_GROUPS='[
    {"subdir": "Base_Case", "label": "基础组", "color": "#2c3e50", "marker": "o"},
    {"subdir": "High_Friction", "label": "高摩擦组", "color": "#e74c3c", "marker": "s"}
]'

# --- 物理模型参数 (m) ---
MODEL_WIDTH=1500.0
MODEL_HEIGHT=500.0

# --- 绘图视口配置 ---
MANUAL_PLOT_Y_MIN=150.0
MANUAL_PLOT_Y_MAX=450.0

# --- 物理截断与演化阈值 ---
MAX_SHORTENING_KM=3.0
MAX_ASPECT_RATIO=1.2

# --- 离散元 (DEM) 颗粒参数 ---
PUSHING_WALL_SIDE=Right
SALT_GROUP_NAME=salt
PARTICLE_RADIUS=1.25
MIN_RELIEF_THRESHOLD=15.0

# --- 算法分箱与平滑 ---
NUM_BINS=300
SMOOTHING_WINDOW=5
EXTRACT_SMOOTH_WINDOW=11
FLANK_SLOPE_THRESHOLD=0.15

# --- 质控界面 UI 调色盘 ---
COLOR_PRIMARY=#3498db
COLOR_SECONDARY=#e67e22
COLOR_GRID=#bdc3c7
COLOR_TEXT_MAIN=#2c3e50
COLOR_TEXT_SUB=#7f8c8d
